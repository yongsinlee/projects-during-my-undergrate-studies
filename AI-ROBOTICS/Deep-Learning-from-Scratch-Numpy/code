class MulLayer:
    def __init__(self):
        self.x = None
        self.y = None

    def forward(self, x, y):
        self.x = x   
        self.y = y
        out = x*y

        return out

    def backward(self, dout):
        dx = y
        dy = x

        return dx, dy

