class Relu:
    def __init__(self):
        self.mask = None # Boolean 값으로 이루어진 배열이다. 입력배열과 동일한 모양을 가지되, True , false 로 이루어진 배열

    def forward(self, x):      # x : 입력값 리스트
        self.mask = (x <= 0)   # 0보다 작은건 mask가 True (boolean)
        out = x.copy()
        out[self.mask] =  0 # masking

        return out

    def backward(self, dout):
        dout[self.mask] = 0      # 0보다 작은 부분에 대해서는 gradient를 0으로 만들어서 tracking을 끊어버림. 순전파의 x<=0 인 위치의 미분값을 0으로 설정하는 부분
        dx =  dout               # 나머지는 그대로 전달

        return dx


