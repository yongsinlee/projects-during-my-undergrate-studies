# 역전파 과정에서 L에 대한 독립변수는 z니까 backward로 들어올때는 z로 편미분. z = x + y를 x,y로 편미분하면 1이니까 역전파시 x,y로의 편미분값은 1

class AddLayer:
    def __init__(self):
        pass

    def forward(self, x, y):
        out =  x + y     
        return out

    def backward(self, dout):
        dx =  dout+1          #  upstream에서 전달된 미분값(dout)을 downstream으로 전달
        dy =  dout+1          
        return dx, dy

