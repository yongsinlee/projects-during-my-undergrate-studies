import numpy as np
class Affine:
    def __init__(self, W, b):
        self.W = W
        self.b = b
        self.x = None
        self.dW = None
        self.db = None

    def forward(self, x):
        self.x = x
        out = np.dot(self.x, self.W) + self.b        # XW + B
        return out

    def backward(self, dout):
        dx = np.dot(dout, self.W.T)            #  상위 계층에서 전달된 미분값과 W값과의 dot 결과
        self.dW = np.dot(self.x.T, dout)       
        self.db =   np.sum(dout, axis=0)       

        return dx

